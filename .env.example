# Pacific Frontend Configuration

# ── Gemini AI (required for standalone mode) ──────────────────────────────────
# Add your Gemini API key to enable AI features when running without Spring Boot
GEMINI_API_KEY=your_gemini_api_key_here

# ── Spring Boot Backend Integration (optional) ────────────────────────────────
# Set to "true" to proxy all /api calls to the Spring Boot backend instead of
# handling them directly with Gemini in this Node.js server.
# USE_SPRING_BACKEND=true
# BACKEND_URL=http://localhost:20260

# ── App URL ──────────────────────────────────────────────────────────────────
# APP_URL=http://localhost:3000
